{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meteor",
  "version": "1.0.3",
  "identifier": "com.alfonso.meteor",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Meteor",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/covers/**", "$APPDATA/user_covers/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "binaries/PresentMon.exe",
      "binaries/cputemp.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MrRobot4042212/Meteor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2Q0MxMDBGOTkzRTE1MzIKUldReUZUNlpEeERNZHJIdm9MamtzV0VLcnJjSERYVG1rRWlZOWNLNnREZGt4QVhxL3UvSjhWUGIK"
    }
  }
}
